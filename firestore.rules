rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the logged-in user is an administrator
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == 'contact@korkinventrex.com' || 
         request.auth.token.email == 'kavyasree@korkinventrex.com');
    }

    // Public collections (anyone can read; only Admins can write)
    match /testimonials/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /products/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /blogs/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Inquiries (anyone can submit/write a new lead; only Admins can read/manage them)
    match /enquiries/{document} {
      allow read, write: if isAdmin();
      allow create: if true;
    }

    match /client_projects/{clientId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == clientId);
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (request.auth != null && request.auth.uid == clientId);

      match /projects/{projectId} {
        allow read: if isAdmin() || (request.auth != null && request.auth.uid == clientId);
        allow write: if isAdmin();
      }
    }

    // Messages
    // Read: Admins or the client owner
    // Write: Admins or the client owner (requires client to match request.auth.uid)
    match /messages/{messageId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.clientId == request.auth.uid);
      allow write: if isAdmin() || (request.auth != null && request.resource.data.clientId == request.auth.uid);
    }

    // Documents
    // Read: Admins or the client owner
    // Write: Admins or the client owner (requires client to match request.auth.uid)
    match /documents/{documentId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.clientId == request.auth.uid);
      allow write: if isAdmin() || (request.auth != null && request.resource.data.clientId == request.auth.uid);
    }

    // Support Tickets
    // Read: Admins or the client owner
    // Create: Authenticated users (must match request.resource.data.clientId)
    // Update: Admins or the client owner
    // Delete: Only Admins
    match /support_tickets/{ticketId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.clientId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.clientId == request.auth.uid;
      allow update: if isAdmin() || (request.auth != null && resource.data.clientId == request.auth.uid && request.resource.data.clientId == request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}
